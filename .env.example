# ============================================================
# Base de datos — SQLite (local, sin servidor)
# ============================================================
# DATABASE_URL apunta a un archivo. Se crea automáticamente al
# correr la primera migración:
#   npx prisma migrate dev --name init
DATABASE_URL="file:./dev.db"

# ============================================================
# NextAuth
# ============================================================
# Local:           http://localhost:3000
# Vercel preview:  la URL del preview deployment
# Vercel prod:     tu dominio (https://app.tudominio.com o https://xxx.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# Genera una clave aleatoria con:
#   openssl rand -base64 32
# IMPORTANTE: cambia esto en producción. Si la cambias, todas las sesiones
# existentes se invalidan (los usuarios deben volver a loguearse).
NEXTAUTH_SECRET="cambia-esto-genera-una-cadena-aleatoria-larga-de-32-bytes"
